# ──────────────────────────────────────────────────────────────
# BitTON.AI — Environment Variables for Testnet Deployment
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before deploying.

# ─── Network ─────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── Basescan Verification ───────────────────────────────────
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ─── Pre-existing Addresses (already deployed on Base Sepolia) ──
# BTN Token (ERC20, 6 decimals, 21M max supply)
BTN_TOKEN_ADDRESS=0x5b964baafEDf002e5364F37848DCa1908D3e4e9f

# USDT on Base Sepolia (use a mock if none available)
USDT_TOKEN_ADDRESS=

# Chainlink BTN/USD price feed on Base Sepolia (use mock if unavailable)
ORACLE_ADDRESS=

# Treasury wallet for fee collection + early-exit penalties
TREASURY_ADDRESS=

# ─── Deployed Contract Addresses (filled in by deploy-all.js) ──
# These are populated automatically after running the deploy script.
# You can also use them with individual deploy-*.js scripts.
VAULT_MANAGER_ADDRESS=
STAKING_VAULT_ADDRESS=
WITHDRAWAL_WALLET_ADDRESS=
VESTING_POOL_ADDRESS=
REWARD_ENGINE_ADDRESS=
BONUS_ENGINE_ADDRESS=

# ─── Reward Pool Funding ─────────────────────────────────────
# Amount of BTN to fund into RewardEngine (6 decimals, e.g. 10000 = 10,000 BTN)
REWARD_FUND_AMOUNT=10000
